# Salin file ini menjadi .env lalu isi dengan nilai asli

SECRET_KEY=ganti-dengan-random-string-panjang

# Midtrans (https://dashboard.midtrans.com → Settings → Access Keys)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_IS_PROD=false   # Ganti ke true saat live

# Stripe (https://dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# URL aplikasi (ganti ke domain asli saat deploy)
APP_URL=http://127.0.0.1:5001
